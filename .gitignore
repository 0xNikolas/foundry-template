# General
node_modules
.DS_Store
.pnp.*
*.log

# Package manager lockfiles from other ecosystems
package-lock.json
pnpm-lock.yaml
yarn.lock

# Foundry files
cache
out
out-via-ir
coverage
lcov.info
crytic-export

# Config files
*.env

# Claude Code
.claude/

# Obsidian
.obsidian/
**/.obsidian/

# Avoid ignoring gitkeep
!/**/.gitkeep

# Foundry broadcast logs — commit real-network deployment records (audit trail:
# tx hashes, block numbers, constructor args; powers forge verify & --resume).
# Ignore only local-chain and dry-run noise (forge-init default).
!/broadcast
/broadcast/*/31337/
/broadcast/*/1337/
/broadcast/**/dry-run/

# Local gstack artifacts (security reports etc.) — never committed
.gstack/

# Serena MCP server local state
.serena/
